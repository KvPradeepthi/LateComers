# OUTLOOK Configuration
OUTLOOK_USER=your_outlook_user@demo.edu
OUTLOOK_PASS=your_outlook_app_password

# Server Port
PORT=5001

# SMTP Email Configuration
EMAIL_USE=your_email_use@demo.edu
EMAIL_PASS=your_email_password

# Database URL (MongoDB)
DBURL=mongodb://127.0.0.1:27017/latecomers_demo

# SMS Gateway Configuration
DAILYMSGURL=https://api.demo.edu/sms/send
SMS_USER=your_sms_gateway_username
SMS_PASS=your_sms_gateway_password

# Node Mailer / Mail Server Configuration
MAIL_HOST=smtp.demo.edu
MAIL_PORT=587
MAIL_USER=your_mail_user@demo.edu
MAIL_PASS=your_mail_password
MAIL_FROM="Monthly Report" <your_mail_from@demo.edu>
MAIL_RECIPIENTS=recipient1@demo.edu,recipient2@demo.edu

# API Endpoints
API_URL=http://localhost:5001/api/student-Monthly-Report
STUDENT_API_URL=https://api.demo.edu/studentdata

# Gemini API Key (Required for AI Natural Language Query Module in Step 4)
GEMINI_API_KEY=your_gemini_api_key_here
